// =============================================================================
// FC_FaultHandler
// -----------------------------------------------------------------------------
// PURPOSE:
//   Runs LAST in the FC chain. Overrides the setpoints written by
//   PowerDistribution and ReactiveControl for any inverter that is faulted,
//   lost comms, or in a global stop condition.
//
//   Also writes OperMode to healthy inverters to keep them in Operation and
//   to recover them after a fault or stop.
//
// FIVE CONDITIONS HANDLED PER INVERTER:
//
//   A) ForceStop = TRUE (EN_PPC = FALSE in the calling FB)
//      → Stop ALL inverters immediately regardless of health.
//
//   B) Plant_Mode = 2 (FALLBACK)
//      → Stop ALL inverters. Comms to SCADA lost; safe state is zero output.
//
//   C) Individual CommError (partial fault)
//      → Stop only this inverter. Set AnyFault and FaultMask bit.
//      → Inverter's own Modbus watchdog trips it if comms stay down.
//
//   D) Active inverter Error (partial fault, sequence S3.1)
//      → Zero setpoints for this inverter. Set AnyFault and FaultMask bit.
//      → Do not acknowledge while fault is active (ErrClr = 0).
//
//   E) Healthy inverter (no globalStop, no CommError, no Error)
//      → Write OperMode=308 to keep in Operation (idempotent).
//      → ErrClr one-shot (sequence S3.3): write 26 (Ackn) exactly once
//        when Error transitions 1→0. PrevError array (passed from FB static)
//        tracks previous Error state per inverter for edge detection.
//      → M6 fix: also send ErrClr=26 when Enabled transitions FALSE→TRUE,
//        in case the one-shot fired while the inverter was disabled and the
//        comms block suppressed the write. PrevEnabled tracks Enabled edges.
//      → PwrOffReas ≠ 0: inverter disconnected abnormally — zero setpoints
//        and set AnyFault, but keep OperMode=308 to allow recovery.
//        PowerDistribution and ReactiveControl already exclude this inverter
//        from distribution; zeroing here is belt-and-suspenders.
//      → DrtStt ≠ 0: inverter is derated (thermal, grid frequency, etc.).
//        Set AnyDerating for HMI alarm. Power is still distributed; WAval
//        already reflects the reduced capacity so the proportional share is
//        naturally lower for a derated unit.
//
// OUTPUTS:
//   AnyFault    — TRUE if any inverter has CommError, Error, or PwrOffReas ≠ 0
//   AnyDerating — TRUE if any healthy inverter has DrtStt ≠ 0
//   FaultMask   — WORD: bit i = inverter i has active CommError or Error
//
// RAMPS RESET:
//   When onlineCount = 0 (all inverters offline), Ramps_Pcmd and Ramps_Qcmd
//   are reset to 0 so both ramps restart from zero when inverters recover.
//
// CALLED FROM: FB_PPC_Controller (step ⑥, last FC in chain)
// =============================================================================

FUNCTION "FC_PPC_FaultHandler" : VOID
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

VAR_INPUT
    // Current plant mode. 2 = FALLBACK → stop all inverters.
    Plant_Mode : INT;

    // TRUE when EN_PPC = FALSE in the calling FB.
    ForceStop : BOOL;
END_VAR

VAR_IN_OUT
    // 10-element inverter array. OperMode, ErrClr and setpoints are written.
    Inverters : Array[0..9] of "Inverter_controller";

    // Reset to 0.0 when all inverters are offline (clean ramp restart).
    Ramps_Pcmd : REAL;

    // Reset to 0.0 when all inverters are offline (clean ramp restart).
    Ramps_Qcmd : REAL;

    // Previous Error state per inverter — stored in FB static section.
    // Used for falling-edge detection to generate the ErrClr one-shot (S3.3).
    PrevError : Array[0..9] of BOOL;

    // Previous Enabled state per inverter — stored in FB static section.
    // Used for rising-edge detection to re-send ErrClr after re-enable (M6).
    PrevEnabled : Array[0..9] of BOOL;
END_VAR

VAR_OUTPUT
    // TRUE if any inverter has an active fault, comms error, or PwrOffReas ≠ 0.
    AnyFault : BOOL;

    // TRUE if any healthy inverter reports a non-zero derating state (DrtStt).
    // Separate from AnyFault — derating does not stop the inverter.
    AnyDerating : BOOL;

    // Bit i = inverter i has active CommError or Error. Used by HMI to show
    // which specific inverters are faulted without browsing all 10 slots.
    FaultMask : WORD;
END_VAR

VAR_TEMP
    i             : INT;    // Loop index
    onlineCount   : INT;    // Inverters fully available after fault evaluation
    globalStop    : BOOL;   // Combined ForceStop / FALLBACK flag
    faultCleared  : BOOL;   // TRUE for one scan when Error transitions 1→0
    enabledRising : BOOL;   // TRUE for one scan when Enabled transitions FALSE→TRUE
END_VAR

BEGIN

    #AnyFault    := FALSE;
    #AnyDerating := FALSE;
    #FaultMask   := WORD#0;
    #onlineCount := 0;

    #globalStop := #ForceStop OR (#Plant_Mode = 2);

    FOR #i := 0 TO 9 DO

        // ── Edge detection ────────────────────────────────────────────────────
        // faultCleared  : Error 1→0 this scan → trigger ErrClr=26 one-shot (S3.3)
        // enabledRising : Enabled FALSE→TRUE → re-send ErrClr=26 in case the
        //   falling-edge one-shot fired while the inverter was disabled (M6 fix)
        #faultCleared  := #PrevError[#i]   AND NOT #Inverters[#i].Error;
        #enabledRising := NOT #PrevEnabled[#i] AND #Inverters[#i].Enabled;
        #PrevError[#i]   := #Inverters[#i].Error;
        #PrevEnabled[#i] := #Inverters[#i].Enabled;

        IF #globalStop THEN
            // ── GLOBAL STOP: issue Stop to ALL inverters (sequence S4) ────────
            // Comms block sees OperMode=303 → writes RemRdy=303 first (S4.1),
            // then InvOpMod=303 (S4.2), satisfying the SMA stop interlock.
            #Inverters[#i].OperMode := 303;   // Stop
            #Inverters[#i].WSpt     := 0;
            #Inverters[#i].VArSpt   := 0;
            #Inverters[#i].PFSpt    := 0;
            #Inverters[#i].WMode    := 303;   // Off
            #Inverters[#i].VArMode  := 303;   // Off
            #Inverters[#i].ErrClr   := 0;

        ELSIF #Inverters[#i].CommError THEN
            // ── INDIVIDUAL COMMS FAULT ────────────────────────────────────────
            // Link broken — write Stop as best-effort. Inverter's own Modbus
            // watchdog will trip it if comms stay down.
            #Inverters[#i].OperMode := 303;
            #Inverters[#i].WSpt     := 0;
            #Inverters[#i].VArSpt   := 0;
            #Inverters[#i].PFSpt    := 0;
            #Inverters[#i].WMode    := 303;
            #Inverters[#i].VArMode  := 303;
            #Inverters[#i].ErrClr   := 0;
            #AnyFault  := TRUE;
            #FaultMask := #FaultMask OR SHL(IN := WORD#1, N := INT_TO_UINT(#i));

        ELSIF #Inverters[#i].Error THEN
            // ── ACTIVE INVERTER FAULT (sequence S3.1) ─────────────────────────
            // ErrStt ≠ 0. Zero setpoints; the inverter trips itself.
            // Do not acknowledge while fault is active (ErrClr = 0).
            // ErrNo (input register 96) should be logged by SCADA (S3.2).
            #Inverters[#i].WSpt    := 0;
            #Inverters[#i].VArSpt  := 0;
            #Inverters[#i].PFSpt   := 0;
            #Inverters[#i].ErrClr  := 0;
            #AnyFault  := TRUE;
            #FaultMask := #FaultMask OR SHL(IN := WORD#1, N := INT_TO_UINT(#i));

        ELSE
            // ── HEALTHY INVERTER ──────────────────────────────────────────────
            // No globalStop, no CommError, no Error.

            // ErrClr one-shot (sequence S3.3):
            // Write 26 (Ackn) exactly once on:
            //   a) Error falling edge (faultCleared) — normal recovery path
            //   b) Enabled rising edge while Error is clear — re-sends Ackn if
            //      the inverter was disabled when the fault cleared and the
            //      comms block suppressed the one-shot write (M6 fix)
            IF #faultCleared OR (#enabledRising AND NOT #Inverters[#i].Error) THEN
                #Inverters[#i].ErrClr := 26;   // Ackn — one-shot, not continuous
            ELSE
                #Inverters[#i].ErrClr := 0;    // Idle
            END_IF;

            // Keep inverter in Operation (idempotent).
            // Comms block writes RemRdy=308 first (S1.1), then InvOpMod=308 (S1.2).
            #Inverters[#i].OperMode := 308;

            // Derating supervision: DrtStt ≠ 0 means thermal, grid frequency,
            // or other derating is active. WAval already reflects reduced capacity
            // so distribution self-corrects; this flag is purely for HMI visibility.
            IF #Inverters[#i].DrtStt <> 0 THEN
                #AnyDerating := TRUE;
            END_IF;

            // PwrOffReas supervision: non-zero means inverter disconnected for
            // an abnormal reason (e.g. code 21626 = "Low Power SetPoint").
            // Treat as unavailable: zero setpoints and flag fault.
            // PowerDistribution/ReactiveControl already excluded this inverter
            // from their online check; zeroing here is belt-and-suspenders.
            IF #Inverters[#i].PwrOffReas <> 0 THEN
                #Inverters[#i].WSpt   := 0;
                #Inverters[#i].VArSpt := 0;
                #Inverters[#i].PFSpt  := 0;
                #AnyFault := TRUE;
                // Not counted — not delivering power
            ELSE
                #onlineCount := #onlineCount + 1;
            END_IF;

        END_IF;

    END_FOR;

    // ── Reset ramps when plant is completely offline ──────────────────────────
    // Ensures both active and reactive ramps restart from zero on recovery
    // rather than jumping to a stale non-zero command.
    IF #onlineCount = 0 THEN
        #Ramps_Pcmd := 0.0;
        #Ramps_Qcmd := 0.0;
    END_IF;

END_FUNCTION
