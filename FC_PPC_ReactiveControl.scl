// =============================================================================
// FC_PPC_ReactiveControl
// -----------------------------------------------------------------------------
// PURPOSE:
//   Distributes the plant-level reactive power command across all online inverters
//   in proportion to each inverter's available reactive power (VArAval), or writes
//   a uniform power factor setpoint when Plant_VArMode = 2.
//
//   This FC is the per-inverter dispatch stage only. Q ramp rate limiting and P-Q
//   capability clamping are performed upstream in FB_PPC_QCapability (step ⑤),
//   which outputs Q_cmd_kVAr — an already-ramped, capability-clamped command.
//
// CONTROL MODES (Plant_VArMode — same signal as Cmd_VArMode from FB_PPC_Controller):
//   0 = Off        — zero reactive output; VArMode = Off (303) for all online inverters
//   1 = Q control  — distribute Q_cmd_kVAr proportionally by VArAval across online inverters
//                    (Q_cmd_kVAr comes from FB_PPC_QCapability, covering both fixed-Q
//                     and voltage-droop modes — the distinction is inside QCapability)
//   2 = PF setpoint — write Targets_PF uniformly to all online inverters; no Q ramp
//                     (PF is dimensionless — no ramp required; bypasses QCapability)
//
// MODE 1 — PROPORTIONAL Q BY VArAval:
//   share_i  = VArAval_i / Σ(VArAval_j)  for all available j
//   VArSpt_i = Q_cmd_kVAr × share_i      [kVAr, FIX0, scaling = 1]
//   VArAval is in pu×10000 (FIX4); cancels in ratio so raw DInt values are used directly.
//
// MODE 2 — UNIFORM PF SETPOINT:
//   Same Targets_PF written to every online inverter.
//   PFSpt register: FIX4 (×10000). Example: 0.950 → 9500, 1.000 → 10000.
//
// ONLINE CRITERIA:
//   Read from Inverters[i].Available — computed once in FC_PPC_InverterMonitor.
//   Not re-derived here — single source of truth avoids drift between FCs.
//
// FALLBACK GUARD:
//   When Plant_Mode = 2, this FC returns immediately without writing anything.
//   FC_PPC_FaultHandler handles the inverter stop sequence in FALLBACK.
//   FB_PPC_QCapability ramps Q_cmd_kVAr to 0 during FALLBACK, so the command
//   is already 0 if FALLBACK ends before the guard here triggers.
//
// CALLED FROM: FB_PPC_Controller (step ⑦, after FB_PPC_QCapability step ⑤)
// =============================================================================

FUNCTION "FC_PPC_ReactiveControl" : VOID
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

VAR_INPUT
    // Reactive control mode: 0 = Off, 1 = Q control, 2 = PF setpoint.
    // From FB_PPC_Controller input Cmd_VArMode.
    Plant_VArMode  : INT;

    // kVAr, plant-level Q command — output of FB_PPC_QCapability.
    // Already ramped and P-Q capability-clamped. Covers both fixed-Q and U-droop modes.
    // Used for per-inverter proportional distribution in mode 1.
    Q_cmd_kVAr     : REAL;

    // Power factor target (e.g. 0.95, 1.00, -0.98 for leading).
    // Written uniformly to all online inverters in mode 2. No ramp — PF is a ratio.
    Targets_PF     : REAL;

    // Current plant mode. FALLBACK (2) → skip distribution entirely.
    Plant_Mode     : INT;

    // When TRUE: simulation mode — no real inverters execute PF control autonomously.
    // In Mode 2 + Sim_Mode: compute equivalent Q from WSpt and Targets_PF and write
    // as VArSpt (VArCtlCom) so PF behaviour is visible in watch table / HMI.
    // In real mode: Mode 2 always sends PFSpt + VArMode=1075 regardless of this flag.
    Sim_Mode       : BOOL;

    // Grid voltage in per-unit — passed from FB_PPC_Controller (U_meas / U_nom_kV).
    // Used in Sim_Mode + Mode 2 to call FC_SMA_QEnvelope and clamp the computed Q
    // to the inverter's physical capability at the current P and voltage.
    U_pu           : REAL;
END_VAR

VAR_IN_OUT
    // 10-element inverter array from DB39.
    // VArSpt, PFSpt, and VArMode are written by this FC.
    Inverters : Array[0..9] of "Inverter_controller";
END_VAR

VAR_TEMP
    i               : INT;    // Loop index
    sumVArAval_raw  : DINT;   // Sum of raw VArAval (pu×10000) for available inverters
    share           : REAL;   // This inverter's fraction of total reactive capacity
    PF_abs          : REAL;   // ABS(Targets_PF) — used in sim PF→Q conversion
    tan_phi         : REAL;   // tan(arccos(PF_abs)) = sqrt(1-PF²)/PF — Q/P ratio
    Q_sim           : REAL;   // Computed Q per inverter for simulation PF mode
    Qmax_inv        : REAL;   // SMA physical Qmax per inverter from FC_SMA_QEnvelope
END_VAR

BEGIN

    // ── Guard: skip in FALLBACK — FaultHandler owns the safe state ────────────
    IF #Plant_Mode = 2 THEN
        RETURN;
    END_IF;

    // ── Pre-compute VArAval sum for proportional Q distribution (mode 1) ──────
    #sumVArAval_raw := 0;
    FOR #i := 0 TO 9 DO
        IF #Inverters[#i].Available THEN
            #sumVArAval_raw := #sumVArAval_raw + #Inverters[#i].VArAval;
        END_IF;
    END_FOR;

    // ── Write reactive setpoints to each inverter ─────────────────────────────
    FOR #i := 0 TO 9 DO

        IF #Inverters[#i].Available THEN

            CASE #Plant_VArMode OF

                0:  // ── Mode 0: No reactive control ───────────────────────────
                    #Inverters[#i].VArSpt  := 0;
                    #Inverters[#i].PFSpt   := 0;
                    #Inverters[#i].VArMode := 303;   // Off

                1:  // ── Mode 1: Q control, distributed by VArAval ─────────────
                    // Q_cmd_kVAr already ramped and capability-clamped by QCapability.
                    // share = VArAval_i / Σ VArAval_j (pu×10000 cancels in ratio)
                    IF #sumVArAval_raw > 0 THEN
                        #share := DINT_TO_REAL(#Inverters[#i].VArAval)
                                  / DINT_TO_REAL(#sumVArAval_raw);
                        #Inverters[#i].VArSpt := REAL_TO_DINT(#Q_cmd_kVAr * #share);
                    ELSE
                        #Inverters[#i].VArSpt := 0;   // No VArAval reported yet
                    END_IF;
                    #Inverters[#i].VArMode := 1072;   // VArCtlCom

                2:  // ── Mode 2: PF setpoint ──────────────────────────────────────
                    IF #Sim_Mode THEN
                        // Simulation: no real inverter executes PF control autonomously.
                        // Compute equivalent Q from this inverter's WSpt and PF target,
                        // then clamp to the SMA physical envelope (same limit the real
                        // inverter's internal PF controller would respect).
                        // Q = P × sqrt(1 - PF²) / |PF| × sign(PF)
                        // sign: positive PF = overexcited = positive Q (capacitive)
                        #PF_abs := ABS(#Targets_PF);
                        IF #PF_abs > 0.1 AND #PF_abs <= 1.0 THEN
                            #tan_phi := SQRT(1.0 - #PF_abs * #PF_abs) / #PF_abs;
                            #Q_sim   := DINT_TO_REAL(#Inverters[#i].WSpt) * #tan_phi;
                            IF #Targets_PF < 0.0 THEN #Q_sim := -#Q_sim; END_IF;
                        ELSE
                            #Q_sim := 0.0;
                        END_IF;
                        // SMA physical envelope clamp — same Stage 2 check as QCapability.
                        // Prevents PF setpoint from requesting Q the inverter cannot deliver.
                        "FC_SMA_QEnvelope"(
                            P_kW      := DINT_TO_REAL(#Inverters[#i].WSpt),
                            U_pu      := #U_pu,
                            Qmax_kVar => #Qmax_inv
                        );
                        IF #Q_sim >  #Qmax_inv THEN #Q_sim :=  #Qmax_inv; END_IF;
                        IF #Q_sim < -#Qmax_inv THEN #Q_sim := -#Qmax_inv; END_IF;
                        #Inverters[#i].VArSpt  := REAL_TO_DINT(#Q_sim);
                        #Inverters[#i].PFSpt   := 0;
                        #Inverters[#i].VArMode := 1072;   // VArCtlCom — Q dispatch in sim
                    ELSE
                        // Real mode: send PF setpoint — inverter controls Q autonomously.
                        // FIX4 format (×10000). Example: 0.950 → 9500, 1.000 → 10000
                        // Guard: SMA rejects PFSpt=0 — default to unity PF if not set yet.
                        #Inverters[#i].VArSpt  := 0;
                        IF ABS(#Targets_PF) > 0.1 THEN
                            #Inverters[#i].PFSpt := REAL_TO_DINT(#Targets_PF * 10000.0);
                        ELSE
                            #Inverters[#i].PFSpt := 10000;   // Unity PF safe default
                        END_IF;
                        #Inverters[#i].VArMode := 1075;   // PFCtlCom
                    END_IF;

            ELSE
                // Unknown mode — default to Off for safety
                #Inverters[#i].VArSpt  := 0;
                #Inverters[#i].PFSpt   := 0;
                #Inverters[#i].VArMode := 303;   // Off

            END_CASE;

        ELSE
            // Inverter offline / faulted — clear all reactive outputs.
            // FaultHandler will additionally issue the Stop command.
            #Inverters[#i].VArSpt  := 0;
            #Inverters[#i].PFSpt   := 0;
            #Inverters[#i].VArMode := 303;   // Off

        END_IF;

    END_FOR;

END_FUNCTION
