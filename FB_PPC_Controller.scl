// =============================================================================
// FB_PPC_Controller  —  Plant Power Controller, main block
// -----------------------------------------------------------------------------
// PURPOSE:
//   Orchestrates the entire PPC control loop. Called from OB30 (cyclic interrupt,
//   default 100 ms). Calls six FCs in a fixed order; each FC feeds the next.
//
// CALL ORDER AND DATA FLOW:
//   ①  FC_PPC_InverterMonitor    →  N_Online, PmaxPlant, QmaxPlant
//   ②  FC_PPC_ModeManager        →  Plant_Mode  (LOCAL / REMOTE_IEC / FALLBACK)
//   ③  FC_PPC_RampControl        →  Ramps_Pcmd  (rate-limited P command in kW)
//   ④  FC_PPC_PowerDistribution  →  WSpt, WMode per inverter
//   ⑤  FC_PPC_ReactiveControl    →  VArSpt / PFSpt / VArMode per inverter
//   ⑥  FC_PPC_FaultHandler       →  OperMode, RemRdy_Spt overrides; AnyFault
//
// DB39 USAGE:
//   The inverter array (PPC_Controller.PPC_Inverters) is passed as VAR_IN_OUT
//   to each FC that needs it. Plant-level scalars (ramp rates, WRtg_kW, etc.)
//   are read directly from the DB by symbol name. After each FC, key internal
//   values are mirrored back to DB39 so the HMI can display them.
//
// WATCHDOG:
//   The IEC_Watchdog input is a toggling bit that the upstream comms thread
//   pulses once per received telegram. This FB detects the rising edge and
//   resets a TON timer. If no edge arrives within Watchdog_Timeout (default 30 s),
//   the timer Q output goes TRUE → ModeManager switches to FALLBACK.
//
// INPUTS FROM UPSTREAM COMMS THREAD (set by caller in OB30):
//   Cmd_P, Cmd_Q, Cmd_PF  — setpoints from SCADA / grid operator
//   Cmd_VArMode            — reactive control mode (0=Off / 1=Q / 2=PF)
//   IEC_Watchdog           — heartbeat toggle bit
//
// CALLED FROM: OB30 (cyclic, 100 ms)
// INSTANCE DB:  assign one DB when placing the FB call in OB30
// =============================================================================

FUNCTION_BLOCK "FB_PPC_Controller"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS  (set by the OB30 network that calls this FB)
// ─────────────────────────────────────────────────────────────────────────────
VAR_INPUT
    // Master enable. FALSE → all inverters commanded to Stop immediately.
    EN_PPC : BOOL;

    // Heartbeat bit from the upstream Modbus/IEC comms thread.
    // Must toggle (0→1 edge) at least once per Watchdog_Timeout period.
    // If no edge is detected, Plant_Mode goes to FALLBACK.
    IEC_Watchdog : BOOL;

    // OB30 cycle time in seconds. Used by RampControl to convert kW/s → kW/scan.
    // Set this to match the actual OB30 interval configured in TIA Portal.
    // Default: 0.1 (100 ms).
    CycleTime_s : REAL;

    // Active power target from upstream SCADA / grid operator, in kW.
    // Passed through RampControl before reaching the inverters.
    Cmd_P : REAL;

    // Reactive power target in kVAr. Used when Cmd_VArMode = 1.
    Cmd_Q : REAL;

    // Power factor target (e.g. 0.95, 1.00). Used when Cmd_VArMode = 2.
    // Sign convention: positive = lagging (inductive), negative = leading.
    Cmd_PF : REAL;

    // Reactive control mode:
    //   0 = Off          (VArMode = 303 on all inverters)
    //   1 = Q setpoint   (distribute Cmd_Q proportionally by VArAval)
    //   2 = PF setpoint  (write uniform Cmd_PF to all online inverters)
    Cmd_VArMode : INT;

    // TRUE when HMI LOCAL/REMOTE selector is in LOCAL.
    // Forces Plant_Mode = 0 (LOCAL) regardless of watchdog or comms.
    LocalMode_Req : BOOL;
END_VAR

// ─────────────────────────────────────────────────────────────────────────────
// OUTPUTS  (visible to HMI, SCADA, and diagnostics)
// ─────────────────────────────────────────────────────────────────────────────
VAR_OUTPUT
    // TRUE when Plant_Mode = 1 (REMOTE_IEC) — controller is active and following
    // the upstream setpoints. Use this for HMI "PPC Running" indicator.
    PPC_Active : BOOL;

    // TRUE when any inverter has an active fault or comms error.
    // Maps to HMI alarm "PPC Fault".
    PPC_Fault : BOOL;

    // Current Plant_Mode value (0/1/2). For HMI display and SCADA reporting.
    Mode_Out : INT;
END_VAR

// ─────────────────────────────────────────────────────────────────────────────
// STATIC  (retained in FB instance DB between OB30 cycles)
// ─────────────────────────────────────────────────────────────────────────────
VAR
    // IEC timer instance for the communication watchdog.
    // Starts counting when no IEC_Watchdog edge is received.
    // Q = TRUE when ET ≥ PT → communication lost → FALLBACK.
    Watchdog_TON : TON;

    // Stores the previous value of IEC_Watchdog for rising-edge detection.
    // Edge = current IEC_Watchdog AND NOT this value.
    Watchdog_LastBit : BOOL;

    // Watchdog timeout period. Configurable from HMI if needed.
    // Default: 30 seconds. Reduce for tighter comms monitoring.
    Watchdog_Timeout : TIME := T#30S;

    // Current plant operating mode. Persists between cycles.
    //   0 = LOCAL      1 = REMOTE_IEC      2 = FALLBACK
    Plant_Mode : INT;

    // Ramped active power command in kW. Accumulates across cycles.
    // RampControl updates this each scan; it MUST persist (not a TEMP).
    Ramps_Pcmd : REAL;

    // Previous Error state per inverter — used by FaultHandler for falling-edge
    // detection to generate the ErrClr=26 one-shot (sequence S3.3).
    // FCs have no static section, so this array lives here and is passed as VAR_IN_OUT.
    PrevError_Arr : Array[0..9] of BOOL;
END_VAR

// ─────────────────────────────────────────────────────────────────────────────
// TEMP  (calculated fresh each OB30 cycle, not retained)
// ─────────────────────────────────────────────────────────────────────────────
VAR_TEMP
    WD_EdgeDetected : BOOL;   // TRUE for exactly one cycle per IEC_Watchdog edge
    WD_Expired      : BOOL;   // Copy of Watchdog_TON.Q output
    N_Online        : INT;    // Online inverter count (from InverterMonitor)
    PmaxPlant       : REAL;   // Total available P in kW (from InverterMonitor)
    QmaxPlant       : REAL;   // Total available Q in kVAr (from InverterMonitor)
    AnyFault        : BOOL;   // Fault flag (from FaultHandler)
END_VAR


BEGIN

    // =========================================================================
    // GUARD: PPC disabled (EN_PPC = FALSE)
    // =========================================================================
    // When the operator disables the PPC, stop all inverters immediately and
    // reset internal state so the next enable starts cleanly from zero.
    IF NOT #EN_PPC THEN
        "FC_PPC_FaultHandler"(
            Plant_Mode := #Plant_Mode,
            ForceStop  := TRUE,                          // Stop everything
            Inverters  := "PPC_Controller".Inverters.PPC_Inverters,
            Ramps_Pcmd := #Ramps_Pcmd,
            PrevError  := #PrevError_Arr,
            AnyFault   => #AnyFault
        );
        // Reset mode and ramp so re-enable starts from a known clean state
        #Plant_Mode  := 0;     // Return to LOCAL when re-enabled
        #Ramps_Pcmd  := 0.0;   // Ramp restarts from 0 on next enable
        // Write outputs
        #PPC_Active  := FALSE;
        #PPC_Fault   := #AnyFault;
        #Mode_Out    := 0;
        // Mirror to DB for HMI
        "PPC_Controller".Plant_Mode   := 0;
        "PPC_Controller".Ramps_Pcmd   := 0.0;
        "PPC_Controller".AnyFault     := #AnyFault;
        RETURN;
    END_IF;


    // =========================================================================
    // WATCHDOG — Rising-edge detection and TON timer management
    // =========================================================================
    // The upstream comms thread toggles IEC_Watchdog once per received telegram.
    // We detect each 0→1 transition and use it to reset the TON timer.
    //
    // HOW TON WORKS HERE:
    //   IN = FALSE → timer immediately resets (ET = 0, Q = FALSE)
    //   IN = TRUE  → timer starts counting up
    //   When ET ≥ PT → Q = TRUE (watchdog expired)
    //
    // By pulsing IN=FALSE for one scan on each edge, we restart the countdown
    // from zero on every new telegram. If telegrams stop, IN stays TRUE and
    // the timer counts up until Q trips → FALLBACK.

    // Detect rising edge of IEC_Watchdog heartbeat
    #WD_EdgeDetected  := #IEC_Watchdog AND NOT #Watchdog_LastBit;
    #Watchdog_LastBit := #IEC_Watchdog;   // Store for next cycle

    IF #WD_EdgeDetected THEN
        // New telegram received: reset watchdog timer to zero
        #Watchdog_TON(IN := FALSE, PT := #Watchdog_Timeout);
    ELSE
        // No new edge this cycle: let timer count up toward timeout
        #Watchdog_TON(IN := TRUE,  PT := #Watchdog_Timeout);
    END_IF;

    #WD_Expired := #Watchdog_TON.Q;   // TRUE when no telegram for > Watchdog_Timeout


    // =========================================================================
    // ①  FC_PPC_InverterMonitor
    // =========================================================================
    // Scans all 10 inverters. Determines which are online and sums their
    // available power. Must run first — all downstream FCs read these results.
    "FC_PPC_InverterMonitor"(
        WRtg_kW   := "PPC_Controller".WRtg_kW,        // Rated kW per inverter (from DB39)
        Inverters  := "PPC_Controller".Inverters.PPC_Inverters,  // The live 10-inverter array
        N_Online   => #N_Online,                       // Result: online count
        PmaxPlant  => #PmaxPlant,                      // Result: available P in kW
        QmaxPlant  => #QmaxPlant                       // Result: available Q in kVAr
    );
    // Mirror to DB39 so HMI can display plant availability
    "PPC_Controller".Plant_N_Online   := #N_Online;
    "PPC_Controller".Limits_PmaxPlant := #PmaxPlant;
    "PPC_Controller".Limits_QmaxPlant := #QmaxPlant;


    // =========================================================================
    // ②  FC_PPC_ModeManager
    // =========================================================================
    // Determines Plant_Mode from watchdog status and HMI override.
    // Priority: LOCAL override > FALLBACK (comms lost) > REMOTE_IEC.
    // Plant_Mode is passed as VAR_IN_OUT — it persists in FB static between cycles.
    "FC_PPC_ModeManager"(
        WD_Expired    := #WD_Expired,     // Watchdog timeout flag
        LocalMode_Req := #LocalMode_Req,  // HMI LOCAL selector
        Plant_Mode    := #Plant_Mode      // VAR_IN_OUT: mode updated here
    );
    "PPC_Controller".Plant_Mode := #Plant_Mode;   // Mirror to DB for HMI


    // =========================================================================
    // ③  FC_PPC_RampControl
    // =========================================================================
    // Applies ramp rate limiting to Cmd_P to produce Ramps_Pcmd.
    // In FALLBACK mode, forces effective target to 0 and ramps down.
    // Ramps_Pcmd is VAR_IN_OUT and persists between cycles — the accumulation
    // IS the ramp; do not reset it between calls.
    "FC_PPC_RampControl"(
        Targets_P  := #Cmd_P,                          // Raw target from upstream
        PmaxPlant  := #PmaxPlant,                      // Upper clamp (available kW)
        P_RampUp    := "PPC_Controller".P_RampUp,       // kW/s from DB39
        P_RampDown  := "PPC_Controller".P_RampDown,    // kW/s from DB39
        CycleTime_s := #CycleTime_s,                   // OB30 interval in seconds
        Plant_Mode := #Plant_Mode,                     // Checked for FALLBACK
        Ramps_Pcmd := #Ramps_Pcmd                      // VAR_IN_OUT: accumulates
    );
    "PPC_Controller".Ramps_Pcmd := #Ramps_Pcmd;   // Mirror for HMI trending


    // =========================================================================
    // ④  FC_PPC_PowerDistribution
    // =========================================================================
    // Splits Ramps_Pcmd proportionally by WAval across online inverters.
    // Writes WSpt (kW) and WMode (1079 = WCtlCom) to each online inverter slot.
    // Returns immediately without writing if Plant_Mode = FALLBACK.
    "FC_PPC_PowerDistribution"(
        Ramps_Pcmd := #Ramps_Pcmd,
        Plant_Mode := #Plant_Mode,
        Inverters  := "PPC_Controller".Inverters.PPC_Inverters
    );


    // =========================================================================
    // ⑤  FC_PPC_ReactiveControl
    // =========================================================================
    // Distributes Q proportionally by VArAval (mode 1), writes uniform PF
    // setpoint (mode 2), or clears reactive outputs (mode 0).
    // Returns immediately without writing if Plant_Mode = FALLBACK.
    "FC_PPC_ReactiveControl"(
        Plant_VArMode := #Cmd_VArMode,
        Targets_Q     := #Cmd_Q,
        Targets_PF    := #Cmd_PF,
        Plant_Mode    := #Plant_Mode,
        Inverters     := "PPC_Controller".Inverters.PPC_Inverters
    );


    // =========================================================================
    // ⑥  FC_PPC_FaultHandler  (always last)
    // =========================================================================
    // Overrides faulted / CommError inverters to safe state.
    // In FALLBACK: stops ALL inverters (setpoints already cleared by ①-⑤ returning
    // early; FaultHandler writes OperMode=Stop and RemRdy=Standby).
    // For healthy inverters: writes OperMode=308 and RemRdy_Spt=308 to keep
    // them in Operation (or to re-start them after recovery).
    // Resets Ramps_Pcmd to 0 if no inverters are online (clean restart on recovery).
    "FC_PPC_FaultHandler"(
        Plant_Mode := #Plant_Mode,
        ForceStop  := FALSE,                             // Normal cycle (not force-stop)
        Inverters  := "PPC_Controller".Inverters.PPC_Inverters,
        Ramps_Pcmd := #Ramps_Pcmd,
        PrevError  := #PrevError_Arr,
        AnyFault   => #AnyFault
    );
    "PPC_Controller".AnyFault := #AnyFault;   // Mirror for HMI alarm


    // =========================================================================
    // OUTPUT ASSIGNMENTS
    // =========================================================================
    #Mode_Out   := #Plant_Mode;
    #PPC_Active := (#Plant_Mode = 1);   // TRUE only in REMOTE_IEC mode
    #PPC_Fault  := #AnyFault;

END_FUNCTION_BLOCK
