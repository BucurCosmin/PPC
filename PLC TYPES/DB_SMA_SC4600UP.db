DATA_BLOCK "DB_SMA_SC4600UP"
// =============================================================================
// SMA Sunny Central 4600 UP — P-Q capability lookup table
// Source: SMA "Sunny Central and Sunny Central Storage — Reactive Power
//         Capability", Version 2021-03-22, Table 1 (SC 4600 UP)
//
// Structure: 4 voltage bins × 21 P breakpoints, stored ascending P (0→Pmax).
// Qmax is symmetric: overexcited (+Qmax) and underexcited (−Qmax) limits equal.
// Rows were reversed from the datasheet's descending order so index 0 = P=0.
//
// Used by: FC_SMA_QEnvelope (2D interpolation → per-inverter Qmax)
// Called from: FB_PPC_QCapability (Stage 2 physical safety clamp)
// =============================================================================
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
NON_RETAIN
   VAR
      Table : "UDT_SMA_QTable";
   END_VAR

